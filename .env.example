# =============================
# Database + Backend
# =============================
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/rewards_db
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
LOG_LEVEL=INFO

# =============================
# Telegram Bot Tokens
# =============================
VERIFIER_BOT_TOKEN=your_verifier_bot_token_here
REWARD_BOT_TOKEN=your_reward_bot_token_here
WELCOME_BOT_TOKEN=your_welcome_bot_token_here

# =============================
# Target Telegram IDs / URLs
# =============================
TARGET_CHANNEL_ID=-1001234567890
TARGET_GROUP_ID=-1009876543210
CHANNEL_JOIN_URL=https://t.me/your_channel
GROUP_JOIN_URL=https://t.me/your_group

# =============================
# Reward amounts
# =============================
REFERRAL_REWARD_AMOUNT=5
VERIFICATION_REWARD_AMOUNT=2

# =============================
# Verifier bot copy + labels
# =============================
VERIFIER_START_TEXT=🔐 <b>Verification Dashboard</b>\nKeep your access active by joining both destinations and tapping verify.
VERIFIER_VERIFY_SUCCESS_TEXT=✅ You are verified! Open the Reward Bot to track rewards.
VERIFIER_VERIFY_FAIL_TEXT=❌ Verification incomplete. Missing: {missing_items}.
VERIFIER_HELP_TEXT=ℹ️ <b>How verification works</b>\n1) Join channel\n2) Join group\n3) Tap Verify Now\nUse Refresh Status anytime to re-check your progress.
VERIFIER_BTN_JOIN_CHANNEL=📢 Join Channel
VERIFIER_BTN_JOIN_GROUP=👥 Join Group
VERIFIER_BTN_VERIFY_NOW=✅ Verify Now
VERIFIER_BTN_REFRESH_STATUS=🔄 Refresh Status
VERIFIER_BTN_HELP=ℹ️ Help
VERIFIER_BTN_BACK=⬅️ Back

# =============================
# Reward bot copy + labels
# =============================
REWARD_NOT_VERIFIED_TEXT=You are not verified yet. Please complete verification in the Verifier Bot first.
REWARD_DASHBOARD_TEXT=🎁 <b>Rewards Dashboard</b>\n🛡 Verification: {verified_badge}\n📌 Reward status: <b>{reward_status}</b>\n👥 Referrals: <b>{referral_count}</b>\n🔗 Invite link: {invite_link}\n\n<b>Reward Breakdown</b>\n⏳ Pending: {pending_rewards}\n✅ Approved: {approved_rewards}\n❌ Rejected: {rejected_rewards}
REWARD_CLAIM_RESULT_TEXT=Claim request processed. {approved_count} rewards approved.
REWARD_HOW_IT_WORKS_TEXT=🧭 <b>How rewards work</b>\n• Verification reward is created when you pass membership checks.\n• Referral rewards are added after invited users verify.\n• Claim Status moves pending rewards to approved/rejected.
REWARD_BTN_REFRESH=🔄 Refresh
REWARD_BTN_MY_REWARDS=💰 My Rewards
REWARD_BTN_REFERRAL_LINK=🔗 My Referral Link
REWARD_BTN_HOW_IT_WORKS=🧭 How It Works
REWARD_BTN_CLAIM_STATUS=🧾 Claim Status
REWARD_BTN_BACK_DASHBOARD=⬅️ Back to Dashboard

# =============================
# Welcome bot copy + labels
# =============================
WELCOME_MESSAGE_TEXT=👋 Welcome {first_name} to {chat_title}!\nRead the rules and enjoy your stay.
WELCOME_BUTTON_TEXT=📌 Group Rules
WELCOME_BUTTON_URL=https://t.me/your_group/1
WELCOME_START_TEXT=👋 <b>Welcome Bot Dashboard</b>\nI greet new members with a polished, configurable welcome message.
WELCOME_HELP_TEXT=ℹ️ <b>Welcome bot tips</b>\n• Supports placeholders: {first_name}, {username}, {chat_title}\n• Uses backend welcome settings per chat\n• Ignores bot accounts when IGNORE_BOTS=true
WELCOME_BTN_REFRESH=🔄 Refresh Settings
WELCOME_BTN_PREVIEW=🧪 Preview Message
WELCOME_BTN_HELP=ℹ️ Help
WELCOME_BTN_BACK=⬅️ Back

# Ignore bot accounts in join events / welcome flow
IGNORE_BOTS=true
