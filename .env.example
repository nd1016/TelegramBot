# =============================
# Database + Backend
# =============================
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/rewards_db
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
LOG_LEVEL=INFO

# =============================
# Telegram Bot Tokens
# =============================
VERIFIER_BOT_TOKEN=your_verifier_bot_token_here
REWARD_BOT_TOKEN=your_reward_bot_token_here
WELCOME_BOT_TOKEN=your_welcome_bot_token_here

# =============================
# Target Telegram IDs / URLs
# =============================
TARGET_CHANNEL_ID=-1001234567890
TARGET_GROUP_ID=-1009876543210
CHANNEL_JOIN_URL=https://t.me/your_channel
GROUP_JOIN_URL=https://t.me/your_group

# =============================
# Reward amounts
# =============================
REFERRAL_REWARD_AMOUNT=5
VERIFICATION_REWARD_AMOUNT=2

# =============================
# Verifier bot copy
# =============================
VERIFIER_START_TEXT=Welcome! Please join our channel and group, then tap Verify.
VERIFIER_VERIFY_SUCCESS_TEXT=✅ You are verified! You can now use the Reward Bot.
VERIFIER_VERIFY_FAIL_TEXT=❌ Verification incomplete. Missing: {missing_items}.

# =============================
# Reward bot copy
# =============================
REWARD_NOT_VERIFIED_TEXT=You are not verified yet. Please complete verification in the Verifier Bot first.
REWARD_DASHBOARD_TEXT=🎁 Reward Dashboard\nStatus: {reward_status}\nReferral count: {referral_count}\nVerification reward: {verification_reward}\nReferral rewards: {referral_reward}\nInvite link: {invite_link}
REWARD_CLAIM_RESULT_TEXT=Claim request processed. {approved_count} rewards approved.

# =============================
# Welcome bot + dashboard
# =============================
WELCOME_MESSAGE_TEXT=👋 Welcome {first_name} to {chat_title}!\nRead the rules and enjoy your stay.
WELCOME_BUTTON_TEXT=📌 Group Rules
WELCOME_BUTTON_URL=https://t.me/your_group/1
WEB_DASHBOARD_BASE_URL=http://127.0.0.1:8000

# Ignore bot accounts in join events / welcome flow
IGNORE_BOTS=true
